import math

main() {
	assert math.sqrt(0 * 0) == 0
	assert math.sqrt(1 * 1) == 1
	assert math.sqrt(2 * 2) == 2
	assert math.sqrt(3 * 3) == 3
	assert math.sqrt(4 * 4) == 4
	assert math.sqrt(5 * 5) == 5
	assert math.sqrt(6 * 6) == 6
	assert math.sqrt(7 * 7) == 7
	assert math.sqrt(8 * 8) == 8
	assert math.sqrt(9 * 9) == 9
	assert math.sqrt(10 * 10) == 10
}